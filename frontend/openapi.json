                "parameters": [
                    {
                        "in": "path",
                        "name": "months",
                        "schema": {
                            "title": "Months",
                            "type": "integer"
                        },
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ActivitySchema"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "title": "Response",
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "tags": [
                    "activity"
                ],
                "security": [
                    {
                        "CanAccessPVE": []
                    }
                ]
            }
        },
