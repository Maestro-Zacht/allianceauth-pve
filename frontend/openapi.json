                "parameters": [],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "items": {
                                        "$ref": "#/components/schemas/RotationSchema"
                                    },
                                    "title": "Response",
                                    "type": "array"
                                }
                            }
                        }
                    }
                },
                "tags": [
                    "rotations"
                ],
                "security": [
                    {
                        "CanAccessPVE": []
                    }
                ]
            }
        },
