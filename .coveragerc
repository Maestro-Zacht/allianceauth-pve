[run]
branch = True
source = ./allianceauth_pve/
omit =
    */tests.py
    */tests/*.py
    */migrations/*
    doc/*
    */scripts/*
    images/*

[report]
exclude_lines =
    if self.debug:
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
ignore_errors = True
